{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:seo": "vitest run --config vitest.seo.config.ts",
    "audit": "tsx scripts/seo-audit.ts",
    "audit:prod": "tsx scripts/seo-audit.ts prod",
    "build:content": "tsx scripts/build-content.ts",
    "build:css": "node scripts/bundle-css.mjs && npx lightningcss-cli --minify public/assets/css/template.bundle.css -o public/assets/css/template.min.css && rm public/assets/css/template.bundle.css",
    "build:images": "node scripts/build-images.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@types/aos": "^3.0.7",
    "aos": "^2.3.4",
    "next": "15.4.11",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5",
    "swiper": "^12.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}